{
  "name": "chat-app",
  "version": "1.2.3",
  "author": "Kamuxx",
  "description": "ChatApp is one application in electron with React",
  "main": "index.js",
  "scripts": {
    "dev": "npm run build:css && nodemon --exec \"npx electron .\"",
    "build:css": "tailwindcss -i ./src/assets/input.css -o ./src/assets/output.css --minify",
    "build": "electron-builder --dir",
    "release": "electron-builder -p always",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "Electronjs",
    "React",
    "node",
    "chatapp",
    "course"
  ],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-notarize": "^1.2.2",
    "nodemon": "^1.0.2",
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "Kamuxx",
      "repo": "chatapp-electron"
    }
  ],
  "build": {
    "appId": "com.github.kamuxx.chatappelectron",
    "productName": "chatapp-electron",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false
    },
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Kamuxx",
        "repo": "chatapp-electron"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kamuxx/chatapp-electron.git"
  }
}